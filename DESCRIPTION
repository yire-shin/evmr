Package: evmr
Type: Package
Title: Extreme Value Modeling for r-Largest Order Statistics
Version: 0.1.0
Authors@R: c(
      person(given = "Yire",
             family = "Shin",
             role = c("aut", "cre"),
             email = "shinyire87@gmail.com",
             comment = c(ORCID = "0000-0003-1297-5430")),
